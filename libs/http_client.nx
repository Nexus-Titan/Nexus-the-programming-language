fn get_data(url)
    out "Fetching JSON from: " + url
    set response = net.get_json(url)
    return response
end
fn post_json(url, data_map)
    out "Sending POST to: " + url
    set payload = json.str(data_map)
    set response = net.post(url, payload)
    return response
end
fn check_endpoint(url)
    set status = net.ping(url)
    if status == 1
        out "Endpoint " + url + " is UP"
        return 1
    else
        out "Endpoint " + url + " is DOWN"
        return 0
    end
end
