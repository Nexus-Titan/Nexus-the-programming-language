fn welcome(name)
    out "Welcome to the Nexus ecosystem, " + name + "!"
    out "Current Time: " + date.now()
end
fn calculate_area(radius)
    set pi = 3.14159
    set area = pi * math.pow(radius, 2)
    return area
end
fn is_even(n)
    set mod = n % 2
    if mod == 0
        return 1
    else
        return 0
    end
end
