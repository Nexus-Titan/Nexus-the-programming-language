fn crawl(url, depth)
    out "Crawling: " + url + " at depth " + depth
    set html = net.get(url)
    return html
end
fn tokenize_raw(code)
    out "Tokenizing source..."
    set t = str.split(code, " ")
    return t
end
fn draw_rect(x, y, w, h, color)
    out "Drawing Rect at " + x + "," + y + " Color: " + color
end
