out "--- Nexus 2.0 ULTRA TEST ---"

set name = "Nexus User"
set version = sys.info()
out "Running on: " + sys.os()
out "User: " + sys.user()

set radius = 10
set area = math.pi() * math.pow(radius, 2)
out "Area of a circle with radius 10: " + area
out "Square root of 144: " + math.sqrt(144)
out "Sine of 90 deg: " + math.sin(math.rad(90))

set msg = "Welcome to Nexus Titan Language"
out "Message length: " + str.len(msg)
out "Uppercase: " + str.upper(msg)
out "Reversed: " + str.reverse(msg)
out "Contains 'Titan': " + str.find(msg, "Titan")

set x = 10
if x > 5
    out "X is greater than 5"
else
    out "X is less than 5"
end

out "Counting to 3..."
loop 3
    out "Iteration!"
end

out "Random number (1-100): " + rnd.int(1, 100)
out "Current time: " + date.now()

gui.msg("Nexus 2.0 ULTRA is ready!")
out "Done."
